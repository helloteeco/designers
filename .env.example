# Design Studio — Environment Variables
# Copy this to .env.local and fill in your values

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Optional: OpenAI (for AI rendering prompt generation) ──
OPENAI_API_KEY=sk-your-key-here

# ── Post Builder (Canva-style carousel generator) ──
# Get from https://console.anthropic.com — used to analyze competitor posts and generate your carousels
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: lets the post builder resolve Instagram URLs via official oEmbed.
# Create a Meta app (free) and paste the access token here. If missing, the
# app falls back to public scraping, then to a "paste screenshots" prompt.
INSTAGRAM_OEMBED_TOKEN=
